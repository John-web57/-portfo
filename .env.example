# Server Configuration
PORT=5000
NODE_ENV=development

# OpenAI API (Optional - for live AI chat assistant)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Gmail Configuration (for contact form emails)
# EMAIL_PASS: Use App Password, NOT your regular Gmail password
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# SendGrid API (Alternative to Gmail - recommended for production)
# Get key from: https://sendgrid.com/
SENDGRID_API_KEY=SG.your-sendgrid-key-here

# Database (SQLite - auto-created in root directory)
DB_PATH=database.sqlite
